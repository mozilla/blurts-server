# Confirm Unsubscription State

unsubscribe-from-breach-alerts-header = Cancelar subscrição dos e-mails de alerta de violações de dados?
unsubscribe-from-breach-alerts-body = Não irá receber mais e-mails instantâneos de alerta de violações de dados de { -brand-mozilla-monitor }.
unsubscribe-link-cta = Cancelar subscrição

# Success Unsubscription State

unsubscribe-success-from-breach-alerts-header = A sua subscrição foi cancelada
unsubscribe-success-from-breach-alerts-body = Pode voltar a subscrever ou atualizar as suas preferências de e-mail a qualquer momento a partir das suas definições do { -brand-monitor }.
unsubscribe-success-link-cta = Iniciar sessão no { -brand-monitor }

# Error warning

unsubscribe-failed = A anulação da subscrição falhou.
