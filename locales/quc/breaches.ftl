breach-all-meta-page-title = Mulib'al juq'attzij rech taq chayub'al juq'attzij — { -brand-fx-monitor }
breach-all-meta-social-title = Ronojel taq retz taqan xriqitaj rumal { -brand-fx-monitor }
breach-all-meta-social-description = Chanik'oj ronojel le ucholajil taq retztaqan le eta'matal uwach le xriqitaj rumal { -brand-fx-monitor }, k'ate k'u ri' chawila' we k'o k'axk'olil chi rij le aq'alajisanem.
# Variables:
#   $company (String) - Name of the company that was breached, e.g. "PHP Freaks"
breach-detail-meta-page-title = { $company } Retztaqan – { -brand-fx-monitor }
# Variables:
#   $company (String) - Name of the company that was breached, e.g. "PHP Freaks"
breach-detail-meta-social-title = La  k'o k'axk'olil ariqon rumal le { $company } Retztaqan?
breach-detail-meta-social-description = Chakojo' { -brand-fx-monitor } chech uriqik we k'o k'axk'olil chi rij le q'alajisanem rech awinaqilal pa we retztaqan, chi'l rilik jas rajawaxik kb'anik.
