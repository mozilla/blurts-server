# Confirm Unsubscription State

unsubscribe-from-breach-alerts-header = ¿Desuscribirse de los correos electrónicos de alerta de filtraciones?
unsubscribe-from-breach-alerts-body = Ya no recibirás correos electrónicos de alerta instantánea sobre filtraciones de { -brand-mozilla-monitor }.
unsubscribe-link-cta = Desuscribirse

# Success Unsubscription State

unsubscribe-success-from-breach-alerts-header = Ahora estás dado de baja.
unsubscribe-success-from-breach-alerts-body = Puede volver a suscribirse o actualizar tus preferencias de correo electrónico en cualquier momento desde tus ajustes de { -brand-monitor }.
unsubscribe-success-link-cta = Conectarse a { -brand-monitor }

# Error warning

unsubscribe-failed = Falló la desuscripción.
