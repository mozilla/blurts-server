# Confirm Unsubscription State

unsubscribe-from-breach-alerts-header = Přestat dostávat e-maily s upozorněním na úniky?
unsubscribe-from-breach-alerts-body = Od služby { -brand-mozilla-monitor } už nebudete dostávat e-maily s upozorněním na úniky dat.
unsubscribe-link-cta = Zrušit odběr

# Success Unsubscription State

unsubscribe-success-from-breach-alerts-header = Nyní jste se odhlásili
unsubscribe-success-from-breach-alerts-body = V nastavení { -brand-monitor(case: "gen") } se můžete kdykoli znovu přihlásit nebo změnit nastavení zasílání e-mailů.
unsubscribe-success-link-cta = Přihlásit se do { -brand-monitor(case: "gen") }

# Error warning

unsubscribe-failed = Odhlášení se nezdařilo.
