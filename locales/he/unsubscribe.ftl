# Confirm Unsubscription State

unsubscribe-from-breach-alerts-header = לבטל את המינוי שלך מהתראות דוא״ל על דליפות נתונים?
unsubscribe-from-breach-alerts-body = לא יתקבלו עוד התרעות מיידיות בדוא״ל על דליפות נתונים מ־{ -brand-mozilla-monitor }.
unsubscribe-link-cta = ביטול מינוי

# Success Unsubscription State

unsubscribe-success-from-breach-alerts-header = המינוי שלך בוטל
unsubscribe-success-from-breach-alerts-body = ניתן להירשם כמינוי מחדש או לעדכן את העדפות הדוא״ל שלך בכל עת דרך הגדרות ה־{ -brand-monitor } שלך.
unsubscribe-success-link-cta = כניסה ל־{ -brand-monitor }

# Error warning

unsubscribe-failed = ביטול המינוי נכשל.
